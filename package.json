{
  "name": "demo-website",
  "module": "src/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build:css": "bunx @tailwindcss/cli -i src/styles/app.css -o dist/styles.css --minify",
    "build:js": "bun build src/main.ts --outdir dist --target browser --minify",
    "build": "bun run build:css && bun run build:js",
    "dev": "bun run build && bun --watch src/server.ts",
    "start": "NODE_ENV=production bun src/server.ts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/bun": "latest",
    "tailwindcss": "^4.2.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
